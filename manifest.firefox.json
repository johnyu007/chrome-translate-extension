{
  "manifest_version": 3,
  "name": "AI 翻译助手",
  "version": "1.0.0",
  "description": "基于 AI 模型的网页实时翻译扩展，复制文本自动翻译。支持 OpenAI 兼容接口（DeepSeek、Ollama、Groq 等）。",
  "permissions": [
    "storage",
    "contextMenus"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "options_page": "settings.html",
  "action": {
    "default_title": "AI 翻译助手",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "ai-translate-assistant@example.com",
      "strict_min_version": "128.0"
    }
  }
}
